# =============================================
# DIARIOPRO - Ejemplo de configuración
# Copiar este archivo como .env y completarlo
# =============================================

# Servidor
PORT=3000
NODE_ENV=development

# Seguridad JWT - Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# Credenciales del administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA

# CORS - Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000
